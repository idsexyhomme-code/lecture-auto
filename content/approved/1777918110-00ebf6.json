        "html": "<div class=\"wrap\" style=\"background:#0A0A0A;color:#F5F5F5;font-family:var(--font-family-sans,'Pretendard',system-ui,sans-serif);overflow:hidden;\">\n\n  <!-- 풀 와이드 스플릿 배너 -->\n  <div style=\"display:grid;grid-template-columns:5fr 4fr;min-height:480px;\">\n\n    <!-- 좌: 타이포 임팩트 존 -->\n    <div style=\"padding:64px 48px;display:flex;flex-direction:column;justify-content:center;position:relative;background:#0A0A0A;\">\n      <!-- 배경 액센트 원 -->\n      <div style=\"position:absolute;top:-120px;left:-80px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,#00E5BE18 0%,transparent 70%);pointer-events:none;\"></div>\n\n      <span style=\"font-size:10px;letter-spacing:0.28em;text-transform:uppercase;color:#00E5BE;font-weight:700;margin-bottom:20px;display:block;\">AI 실무 · Claude 특화</span>\n\n      <h2 style=\"font-size:clamp(36px,5vw,64px);font-weight:900;line-height:1.05;letter-spacing:-0.04em;margin:0 0 28px;\">\n        <span style=\"display:block;\">일하는 방식을</span>\n        <span style=\"display:block;color:#00E5BE;\">AI로 재설계</span>\n        <span style=\"display:block;\">하는 과정</span>\n      </h2>\n\n      <p style=\"font-size:15px;line-height:1.75;color:#8A8A8A;max-width:380px;margin:0 0 36px;\">프롬프트 한 줄 이상의 이야기. Claude를 실제 업무 흐름에 통합하는 구조를 배웁니다.</p>\n\n      <div style=\"display:flex;gap:12px;flex-wrap:wrap;\">\n        <a href=\"#start\" style=\"display:inline-flex;align-items:center;gap:8px;background:#00E5BE;color:#0A0A0A;font-size:14px;font-weight:800;letter-spacing:0.02em;padding:14px 26px;border-radius:4px;text-decoration:none;\">무료로 시작하기 →</a>\n        <a href=\"#curriculum\" style=\"display:inline-flex;align-items:center;gap:8px;background:transparent;color:#F5F5F5;font-size:14px;font-weight:600;padding:14px 26px;border-radius:4px;text-decoration:none;border:1px solid #2A2A2A;\">커리큘럼 →</a>\n      </div>\n    </div>\n\n    <!-- 우: 비주얼 + 정보 카드 스택 -->\n    <div style=\"background:#141414;display:flex;flex-direction:column;justify-content:center;gap:3px;padding:3px;\">\n\n      <!-- 비주얼 플레이스홀더 -->\n      <div style=\"flex:1;background:#1C1C1C;display:flex;align-items:center;justify-content:center;min-height:240px;position:relative;overflow:hidden;\">\n        <img src=\"/assets/placeholder/home_intro-tech.svg\" alt=\"AI 실무 시각화\" style=\"width:100%;height:100%;object-fit:cover;opacity:0.7;\">\n        <div style=\"position:absolute;inset:0;background:linear-gradient(135deg,transparent 60%,#00E5BE12 100%);\"></div>\n        <span style=\"position:absolute;bottom:12px;right:12px;font-size:9px;letter-spacing:0.16em;color:#00E5BE;opacity:0.7;\">CORE · AI</span>\n      </div>\n\n      <!-- 정보 카드 행 -->\n      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:3px;\">\n        <div style=\"background:#1C1C1C;padding:20px;\">\n          <p style=\"font-size:28px;font-weight:900;color:#00E5BE;margin:0 0 4px;letter-spacing:-0.03em;\">28<span style=\"font-size:16px;\">개</span></p>\n          <p style=\"font-size:11px;color:#5A5A5A;margin:0;letter-spacing:0.04em;\">실무 모듈</p>\n        </div>\n        <div style=\"background:#1C1C1C;padding:20px;\">\n          <p style=\"font-size:28px;font-weight:900;color:#F5F5F5;margin:0 0 4px;letter-spacing:-0.03em;\">3,400<span style=\"font-size:16px;\">+</span></p>\n          <p style=\"font-size:11px;color:#5A5A5A;margin:0;letter-spacing:0.04em;\">수강 중인 창업가</p>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  <!-- 하단 태그 스트립 -->\n  <div style=\"background:#141414;padding:16px 48px;display:flex;gap:8px;flex-wrap:wrap;align-items:center;border-top:1px solid #1E1E1E;\">\n    <span style=\"font-size:10px;color:#5A5A5A;letter-spacing:0.12em;margin-right:8px;\">다루는 주제</span>\n    <span style=\"font-size:12px;color:#8A8A8A;background:#1E1E1E;padding:5px 12px;border-radius:2px;\">Claude 프롬프트</span>\n    <span style=\"font-size:12px;color:#8A8A8A;background:#1E1E1E;padding:5px 12px;border-radius:2px;\">업무 자동화</span>\n    <span style=\"font-size:12px;color:#8A8A8A;background:#1E1E1E;padding:5px 12px;border-radius:2px;\">콘텐츠 생산</span>\n    <span style=\"font-size:12px;color:#8A8A8A;background:#1E1E1E;padding:5px 12px;border-radius:2px;\">제안서·보고서</span>\n    <span style=\"font-size:12px;color:#00E5BE;background:#00E5BE1A;padding:5px 12px;border-radius:2px;border:1px solid #00E5BE33;\">1인 운영 특화</span>\n  </div>\n\n</div>",
